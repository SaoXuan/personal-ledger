<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  />
  <style>
    .hero-card {
      background: linear-gradient(135deg, #0d6efd 0%, #5b8def 45%, #8ec5ff 100%);
      color: #fff;
      overflow: hidden;
      position: relative;
    }
    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -60px -100px auto;
      width: 220px;
      height: 220px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.18);
    }
    .metric-card {
      border: 0;
      border-radius: 1rem;
      box-shadow: 0 0.6rem 1.6rem rgba(15, 23, 42, 0.08);
    }
    .return-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.25rem;
      border-radius: 999px;
      padding: 0.25rem 0.65rem;
      font-weight: 700;
      font-size: 0.85rem;
    }
    .return-up { color: #087f5b; background: #d3f9d8; }
    .return-down { color: #c92a2a; background: #ffe3e3; }
    .return-flat { color: #495057; background: #f1f3f5; }
    .sticky-actions { position: sticky; right: 0; background: #fff; }
    .table > :not(caption) > * > * { vertical-align: middle; }
  </style>
</head>
<body class="bg-body-tertiary">
  <nav class="navbar navbar-expand-lg bg-primary navbar-dark shadow-sm">
    <div class="container">
      <span class="navbar-brand fw-semibold">Personal Ledger · RMB</span>
      <div class="d-flex align-items-center gap-2 text-white-50">
        <span id="statusText" class="small">数据按需刷新</span>
        <button class="btn btn-sm btn-light" id="refreshBtn">刷新</button>
      </div>
    </div>
  </nav>

  <main class="container py-3">
    <div id="toastContainer" class="mb-3"></div>

    <div class="row g-3 mb-3">
      <div class="col-12 col-xl-5">
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <h5 class="card-title mb-3">快速记账</h5>
            <form id="quickSnapshotForm" class="row g-2">
              <div class="col-12">
                <label class="form-label">账户</label>
                <select class="form-select" id="quickAccountSelect" name="account_id" required></select>
              </div>
              <div class="col-md-6">
                <label class="form-label">月份</label>
                <input type="month" class="form-control" name="snapshot_month" value="<%= currentMonth %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">余额（RMB）</label>
                <input type="text" class="form-control" name="balance" placeholder="例如 120000.55" required />
              </div>
              <div class="col-12 d-grid">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check2-circle me-1"></i>保存
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-7">
        <div class="row g-3">
          <div class="col-12 col-lg-6">
            <div class="card metric-card hero-card h-100">
              <div class="card-body position-relative">
                <div class="small opacity-75">总资产（RMB）</div>
                <div id="cardTotalRmb" class="display-6 fw-bold">0.00</div>
                <div class="mt-2 small opacity-75">最新月份：<span id="cardLastDate">-</span></div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="text-secondary small">总资产变化</div>
                <div id="cardTotalChange" class="fs-4 fw-bold">-</div>
                <div id="cardTotalChangeRange" class="small text-secondary">等待下月数据</div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="text-secondary small">总收益率</div>
                <div id="cardTotalReturn" class="fs-4 fw-bold">-</div>
                <div class="small text-secondary">按相邻两个月余额估算</div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="text-secondary small">账户数量</div>
                <div id="cardAccountsCount" class="fs-4 fw-bold">0</div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="text-secondary small">记录条数</div>
                <div id="cardSnapshotsCount" class="fs-4 fw-bold">0</div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="card shadow-sm border-0">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h6 class="mb-0">月度资产变化（RMB 汇总）</h6>
                </div>
                <div class="table-responsive">
                  <table class="table table-sm align-middle mb-0">
                    <thead>
                      <tr>
                        <th>月份</th>
                        <th class="text-end">总资产（RMB）</th>
                      </tr>
                    </thead>
                    <tbody id="trendTbody"></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-xl-6">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">账户收益率概览</span>
            <button class="btn btn-sm btn-primary" id="openAccountModalBtn">
              <i class="bi bi-plus-circle me-1"></i>新增账户
            </button>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>账户名称</th>
                    <th class="text-end">最新余额</th>
                    <th class="text-end">上期余额</th>
                    <th class="text-end">资金变化</th>
                    <th class="text-end">收益率</th>
                    <th class="text-end sticky-actions">操作</th>
                  </tr>
                </thead>
                <tbody id="accountsTbody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-6">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-white fw-semibold">最近余额记录</div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>日期</th>
                    <th>账户</th>
                    <th class="text-end">余额（RMB）</th>
                    <th class="text-end">操作</th>
                  </tr>
                </thead>
                <tbody id="snapshotsTbody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="accountFormDialog">
          <div class="modal-header">
            <h5 class="modal-title" id="accountModalTitle">新增账户</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" name="id" />
            <label class="form-label">账户名称</label>
            <input class="form-control" name="name" required placeholder="例如：招商银行 / 币安现货 / 工资卡" />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
            <button type="submit" class="btn btn-primary">保存</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/app.js"></script>
</body>
</html>
