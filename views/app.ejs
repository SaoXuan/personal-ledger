<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  />
  <style>
    :root {
      --ledger-bg: #eef4fb;
      --ledger-surface: rgba(255, 255, 255, 0.88);
      --ledger-surface-strong: #ffffff;
      --ledger-border: rgba(100, 116, 139, 0.16);
      --ledger-text: #0f172a;
      --ledger-muted: #64748b;
      --ledger-primary: #2563eb;
      --ledger-primary-dark: #1d4ed8;
      --ledger-green: #16a34a;
      --ledger-red: #dc2626;
      --ledger-shadow: 0 18px 45px rgba(15, 23, 42, 0.10);
      --ledger-radius: 1.35rem;
    }
    * { -webkit-font-smoothing: antialiased; }
    body {
      color: var(--ledger-text);
      min-height: 100vh;
      background:
        radial-gradient(circle at 8% 0%, rgba(37, 99, 235, 0.18), transparent 30rem),
        radial-gradient(circle at 92% 10%, rgba(22, 163, 74, 0.16), transparent 27rem),
        linear-gradient(180deg, #f8fbff 0%, var(--ledger-bg) 42%, #f7fafc 100%) !important;
    }
    .navbar {
      background: rgba(15, 23, 42, 0.86) !important;
      border-bottom: 1px solid rgba(255,255,255,.12);
      backdrop-filter: blur(18px);
    }
    .navbar-brand { letter-spacing: .01em; }
    main.container { max-width: 1320px; }
    .hero-card {
      background:
        radial-gradient(circle at 85% 20%, rgba(255,255,255,.24), transparent 13rem),
        linear-gradient(135deg, #1d4ed8 0%, #2563eb 50%, #16a34a 118%);
      color: #fff;
      overflow: hidden;
      position: relative;
      min-height: 166px;
    }
    .hero-card::after {
      content: "";
      position: absolute;
      inset: auto -72px -112px auto;
      width: 260px;
      height: 260px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.16);
    }
    .metric-card,
    .panel-card,
    .quick-card {
      border: 1px solid var(--ledger-border) !important;
      border-radius: var(--ledger-radius);
      box-shadow: var(--ledger-shadow);
      background: var(--ledger-surface);
      backdrop-filter: blur(18px);
    }
    .metric-card { transition: transform .18s ease, box-shadow .18s ease; }
    .metric-card:hover { transform: translateY(-2px); box-shadow: 0 22px 50px rgba(15,23,42,.13); }
    .card-header {
      border-bottom-color: rgba(100,116,139,.14);
      border-radius: var(--ledger-radius) var(--ledger-radius) 0 0 !important;
    }
    .section-title { letter-spacing: .01em; color: var(--ledger-text); }
    .return-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.25rem;
      border-radius: 999px;
      padding: 0.32rem 0.72rem;
      font-weight: 800;
      font-size: 0.84rem;
      white-space: nowrap;
      min-width: 5.8rem;
      border: 1px solid transparent;
    }
    .return-up { color: #047857; background: #dcfce7; border-color: #bbf7d0; }
    .return-down { color: #b91c1c; background: #fee2e2; border-color: #fecaca; }
    .return-flat { color: #475569; background: #f1f5f9; border-color: #e2e8f0; }
    .account-name-cell { min-width: 180px; }
    .sticky-actions { position: sticky; right: 0; background: rgba(255,255,255,.96); box-shadow: -0.55rem 0 1rem rgba(255,255,255,.86); }
    .table { --bs-table-hover-bg: rgba(37, 99, 235, 0.045); }
    .table > :not(caption) > * > * { vertical-align: middle; padding-top: .85rem; padding-bottom: .85rem; }
    .table thead th { font-size: .76rem; color: var(--ledger-muted); text-transform: uppercase; letter-spacing: .045em; font-weight: 800; }
    .metric-label { color: var(--ledger-muted); font-size: .82rem; font-weight: 700; }
    .metric-value { line-height: 1.12; letter-spacing: -.02em; }
    .metric-icon {
      width: 2.3rem;
      height: 2.3rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--ledger-primary);
      background: rgba(37,99,235,.10);
      border-radius: .9rem;
      flex: 0 0 auto;
    }
    .hero-kicker { text-transform: uppercase; letter-spacing: .11em; font-weight: 800; }
    .hero-meta { display: inline-flex; align-items: center; gap: .35rem; padding: .38rem .72rem; border-radius: 999px; background: rgba(255,255,255,.16); }
    .panel-card { overflow: hidden; }
    .table-responsive { scrollbar-color: rgba(100,116,139,.38) transparent; }
    .form-label { color: #334155; font-weight: 700; font-size: .86rem; margin-bottom: .38rem; }
    .form-control,
    .form-select {
      border-color: rgba(100,116,139,.22);
      border-radius: .9rem;
      min-height: 2.75rem;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.6);
    }
    .form-control:focus,
    .form-select:focus {
      border-color: rgba(37,99,235,.55);
      box-shadow: 0 0 0 .22rem rgba(37,99,235,.12);
    }
    .input-group-text { border-radius: .9rem; border-color: rgba(100,116,139,.22); background: #f8fafc; color: var(--ledger-muted); font-weight: 800; }
    .btn { border-radius: .85rem; font-weight: 700; }
    .btn-primary { background: linear-gradient(135deg, var(--ledger-primary), var(--ledger-primary-dark)); border-color: transparent; box-shadow: 0 10px 20px rgba(37,99,235,.18); }
    #toastContainer { position: sticky; top: .75rem; z-index: 20; }
    .alert { border: 0; border-radius: 1rem; box-shadow: 0 12px 30px rgba(15,23,42,.10); }
    @media (max-width: 575.98px) {
      .navbar .container { align-items: flex-start !important; gap: .65rem; }
      .navbar-brand { font-size: 1rem; white-space: normal; line-height: 1.25; }
      #statusText { display: none; }
      main.container { padding-left: .85rem; padding-right: .85rem; }
      .card-body { padding: 1rem; }
      .hero-card { min-height: 142px; }
      .hero-card .display-5 { font-size: 2rem; word-break: break-word; }
      .metric-icon { width: 2rem; height: 2rem; border-radius: .75rem; }
      .quick-card,
      .metric-card,
      .panel-card { border-radius: 1rem; box-shadow: 0 12px 30px rgba(15,23,42,.09); }
      .card-header { padding: .9rem 1rem; gap: .75rem; }
      .card-header .btn { white-space: nowrap; }
      .table > :not(caption) > * > * { padding: .72rem .65rem; }
      .table thead th { font-size: .7rem; }
      .sticky-actions { position: static; box-shadow: none; background: transparent; }
      .account-name-cell { min-width: 150px; }
      .btn-group-sm > .btn, .btn-sm { --bs-btn-padding-y: .35rem; --bs-btn-padding-x: .55rem; }
    }
    .text-tabular { font-variant-numeric: tabular-nums; }
  </style>
</head>
<body class="bg-body-tertiary">
  <nav class="navbar navbar-expand-lg bg-primary navbar-dark shadow-sm">
    <div class="container">
      <span class="navbar-brand fw-semibold">Personal Ledger · RMB</span>
      <div class="d-flex align-items-center gap-2 text-white-50">
        <span id="statusText" class="small">数据按需刷新</span>
        <button class="btn btn-sm btn-light" id="refreshBtn">刷新</button>
      </div>
    </div>
  </nav>

  <main class="container py-3">
    <div id="toastContainer" class="mb-3"></div>

    <div class="row g-3 mb-3">
      <div class="col-12 col-xl-5">
        <div class="card quick-card shadow-sm bg-white border-0">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-3">
              <div>
                <h5 class="card-title mb-1 section-title">快速记账</h5>
                <div class="text-secondary small">录入每月账户余额，自动计算本月与累计收益率</div>
              </div>
              <span class="badge text-bg-primary-subtle text-primary rounded-pill">RMB</span>
            </div>
            <form id="quickSnapshotForm" class="row g-2">
              <div class="col-12">
                <label class="form-label">账户</label>
                <select class="form-select" id="quickAccountSelect" name="account_id" required></select>
              </div>
              <div class="col-md-6">
                <label class="form-label">月份</label>
                <input type="month" class="form-control" name="snapshot_month" value="<%= currentMonth %>" required />
              </div>
              <div class="col-md-6">
                <label class="form-label">余额（RMB）</label>
                <div class="input-group">
                  <span class="input-group-text">¥</span>
                  <input type="text" class="form-control" name="balance" placeholder="例如 120000.55" inputmode="decimal" required />
                </div>
              </div>
              <div class="col-12 d-grid">
                <button type="submit" class="btn btn-primary">
                  <i class="bi bi-check2-circle me-1"></i>保存
                </button>
              </div>
            </form>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-7">
        <div class="row g-3">
          <div class="col-12 col-lg-6">
            <div class="card metric-card hero-card h-100">
              <div class="card-body position-relative d-flex flex-column justify-content-between">
                <div>
                  <div class="small opacity-75 hero-kicker mb-2">Portfolio Overview</div>
                  <div id="cardTotalRmb" class="display-5 fw-bold metric-value text-tabular">0.00</div>
                </div>
                <div class="mt-3 d-flex flex-wrap gap-2 small opacity-90">
                  <span class="hero-meta"><i class="bi bi-calendar3"></i>最新月份 <span id="cardLastDate">-</span></span>
                  <span class="hero-meta"><i class="bi bi-currency-yen"></i>RMB 汇总</span>
                </div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                  <div class="metric-label">总资产变化</div>
                  <span class="metric-icon"><i class="bi bi-graph-up-arrow"></i></span>
                </div>
                <div id="cardTotalChange" class="fs-4 fw-bold metric-value text-tabular">-</div>
                <div id="cardTotalChangeRange" class="small text-secondary mt-1">等待下月数据</div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                  <div class="metric-label">总收益率</div>
                  <span class="metric-icon"><i class="bi bi-percent"></i></span>
                </div>
                <div id="cardTotalReturn" class="fs-4 fw-bold metric-value">-</div>
                <div class="small text-secondary mt-1">按相邻两个月余额估算</div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                  <div class="metric-label">账户数量</div>
                  <span class="metric-icon"><i class="bi bi-wallet2"></i></span>
                </div>
                <div id="cardAccountsCount" class="fs-4 fw-bold metric-value text-tabular">0</div>
              </div>
            </div>
          </div>
          <div class="col-sm-6 col-lg-3">
            <div class="card metric-card h-100">
              <div class="card-body">
                <div class="d-flex align-items-start justify-content-between gap-2 mb-3">
                  <div class="metric-label">记录条数</div>
                  <span class="metric-icon"><i class="bi bi-journal-check"></i></span>
                </div>
                <div id="cardSnapshotsCount" class="fs-4 fw-bold metric-value text-tabular">0</div>
              </div>
            </div>
          </div>

          <div class="col-12">
            <div class="card panel-card">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h6 class="mb-0">月度资产变化（RMB 汇总）</h6>
                </div>
                <div class="table-responsive">
                  <table class="table table-sm align-middle mb-0">
                    <thead>
                      <tr>
                        <th>月份</th>
                        <th class="text-end">总资产（RMB）</th>
                      </tr>
                    </thead>
                    <tbody id="trendTbody"></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-12 col-xl-6">
        <div class="card panel-card">
          <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <span class="fw-semibold">账户收益率概览</span>
            <button class="btn btn-sm btn-primary" id="openAccountModalBtn">
              <i class="bi bi-plus-circle me-1"></i>新增账户
            </button>
          </div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th class="account-name-cell">账户名称</th>
                    <th class="text-end">最新余额</th>
                    <th class="text-end">本月变化</th>
                    <th class="text-end">本月收益率</th>
                    <th class="text-end">累计变化</th>
                    <th class="text-end">累计收益率</th>
                    <th class="text-end sticky-actions">操作</th>
                  </tr>
                </thead>
                <tbody id="accountsTbody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-12 col-xl-6">
        <div class="card panel-card">
          <div class="card-header bg-white fw-semibold">最近余额记录</div>
          <div class="card-body p-0">
            <div class="table-responsive">
              <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>日期</th>
                    <th>账户</th>
                    <th class="text-end">余额（RMB）</th>
                    <th class="text-end">操作</th>
                  </tr>
                </thead>
                <tbody id="snapshotsTbody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="accountFormDialog">
          <div class="modal-header">
            <h5 class="modal-title" id="accountModalTitle">新增账户</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" name="id" />
            <label class="form-label">账户名称</label>
            <input class="form-control" name="name" required placeholder="例如：招商银行 / 币安现货 / 工资卡" />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
            <button type="submit" class="btn btn-primary">保存</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/app.js"></script>
</body>
</html>
