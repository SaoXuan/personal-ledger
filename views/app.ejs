<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title %></title>
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
    rel="stylesheet"
  />
  <style>
    /* ═══════════════ Design Tokens ═══════════════ */
    :root {
      --pl-bg: #f7f8fa;
      --pl-surface: #ffffff;
      --pl-border: #e5e7eb;
      --pl-border-light: #f3f4f6;
      --pl-text: #111827;
      --pl-text-2: #6b7280;
      --pl-text-3: #9ca3af;
      --pl-accent: #6366f1;
      --pl-accent-hover: #4f46e5;
      --pl-accent-light: rgba(99,102,241,.08);
      --pl-green: #10b981;
      --pl-green-bg: #ecfdf5;
      --pl-green-border: #d1fae5;
      --pl-red: #ef4444;
      --pl-red-bg: #fef2f2;
      --pl-red-border: #fee2e2;
      --pl-radius: 12px;
      --pl-radius-sm: 8px;
      --pl-radius-xs: 6px;
      --pl-shadow: 0 1px 3px rgba(0,0,0,.04), 0 1px 2px rgba(0,0,0,.06);
      --pl-shadow-hover: 0 4px 12px rgba(0,0,0,.08);
      --pl-transition: 150ms ease;
      --pl-font: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    }

    /* ═══════════════ Base ═══════════════ */
    * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body {
      font-family: var(--pl-font) !important;
      background: var(--pl-bg) !important;
      color: var(--pl-text);
      min-height: 100vh;
    }

    /* ═══════════════ Navbar ═══════════════ */
    .pl-navbar {
      background: var(--pl-surface);
      border-bottom: 1px solid var(--pl-border);
      padding: 0 1rem;
      height: 52px;
      display: flex;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 100;
    }
    .pl-navbar-inner {
      max-width: 1280px;
      margin: 0 auto;
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .pl-brand {
      font-weight: 600;
      font-size: .9rem;
      color: var(--pl-text);
      display: flex;
      align-items: center;
      gap: .5rem;
    }
    .pl-brand-dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--pl-accent);
    }
    .pl-nav-actions {
      display: flex;
      align-items: center;
      gap: .75rem;
    }
    .pl-nav-status { font-size: .75rem; color: var(--pl-text-3); }
    .pl-btn-refresh {
      font-size: .8rem;
      padding: .35rem .75rem;
      border-radius: var(--pl-radius-xs);
      border: 1px solid var(--pl-border);
      background: var(--pl-surface);
      color: var(--pl-text-2);
      cursor: pointer;
      font-weight: 500;
      transition: all var(--pl-transition);
    }
    .pl-btn-refresh:hover { border-color: var(--pl-accent); color: var(--pl-accent); }

    /* ═══════════════ Layout ═══════════════ */
    .pl-container { max-width: 1280px; margin: 0 auto; padding: 1.25rem 1rem; }

    /* ═══════════════ Quick Entry ═══════════════ */
    .quick-card {
      background: var(--pl-surface);
      border: 1px solid var(--pl-border);
      border-radius: var(--pl-radius);
      box-shadow: var(--pl-shadow);
      overflow: hidden;
    }
    .quick-header {
      padding: .65rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      cursor: pointer;
      user-select: none;
      font-size: .8rem;
      font-weight: 600;
      color: var(--pl-text-2);
      letter-spacing: .02em;
      text-transform: uppercase;
      transition: color var(--pl-transition);
    }
    .quick-header:hover { color: var(--pl-text); }
    .quick-header .chevron-icon { transition: transform var(--pl-transition); font-size: .7rem; }
    .quick-header[aria-expanded="false"] .chevron-icon { transform: rotate(-90deg); }
    .quick-form {
      padding: .75rem 1rem 1rem;
      display: flex;
      gap: .75rem;
      align-items: flex-end;
      border-top: 1px solid var(--pl-border-light);
    }
    .quick-form .form-group { flex: 1; min-width: 0; }
    .quick-form .form-group-amount { flex: 1.2; }
    .quick-form .form-group label {
      display: block;
      font-size: .72rem;
      font-weight: 500;
      color: var(--pl-text-3);
      margin-bottom: .3rem;
      text-transform: uppercase;
      letter-spacing: .04em;
      text-align: left;
    }
    .quick-form .form-control,
    .quick-form .form-select {
      height: 36px;
      font-size: .82rem;
      border-radius: var(--pl-radius-xs);
      border: 1px solid var(--pl-border);
      padding: 0 .6rem;
    }
    .quick-form .form-control:focus,
    .quick-form .form-select:focus {
      border-color: var(--pl-accent);
      box-shadow: 0 0 0 3px var(--pl-accent-light);
    }
    .quick-form .input-group { display: flex; }
    .quick-form .input-group .input-group-text {
      height: 36px;
      font-size: .82rem;
      border-radius: var(--pl-radius-xs) 0 0 var(--pl-radius-xs);
      border: 1px solid var(--pl-border);
      border-right: 0;
      background: var(--pl-border-light);
      color: var(--pl-text-3);
      padding: 0 .5rem;
      font-weight: 600;
      display: flex;
      align-items: center;
    }
    .quick-form .input-group .form-control {
      border-radius: 0 var(--pl-radius-xs) var(--pl-radius-xs) 0;
    }
    .btn-submit {
      height: 36px;
      padding: 0 1.25rem;
      font-size: .82rem;
      font-weight: 600;
      border: none;
      border-radius: var(--pl-radius-xs);
      background: var(--pl-accent);
      color: #fff;
      cursor: pointer;
      white-space: nowrap;
      transition: background var(--pl-transition);
      display: inline-flex;
      align-items: center;
      gap: .35rem;
    }
    .btn-submit:hover { background: var(--pl-accent-hover); }

    /* ═══════════════ Hero Card ═══════════════ */
    .hero-card {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      border-radius: var(--pl-radius);
      color: #fff;
      padding: 1.75rem;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      min-height: 210px;
      box-shadow: 0 4px 24px rgba(15,23,42,.18);
    }
    .hero-card::before {
      content: "";
      position: absolute;
      top: -40px; right: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: rgba(99,102,241,.15);
    }
    .hero-card::after {
      content: "";
      position: absolute;
      bottom: -60px; left: -20px;
      width: 120px; height: 120px;
      border-radius: 50%;
      background: rgba(16,185,129,.1);
    }
    .hero-label {
      font-size: .72rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: rgba(255,255,255,.5);
      margin-bottom: .5rem;
    }
    .hero-amount {
      font-size: 2.5rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      letter-spacing: -.02em;
      line-height: 1.1;
      position: relative;
      z-index: 1;
    }
    .hero-footer {
      display: flex;
      align-items: center;
      gap: .75rem;
      margin-top: 1rem;
      position: relative;
      z-index: 1;
    }
    .hero-meta {
      display: inline-flex;
      align-items: center;
      gap: .35rem;
      font-size: .75rem;
      color: rgba(255,255,255,.55);
      padding: .25rem .6rem;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
    }
    .hero-change-badge {
      display: inline-flex;
      align-items: center;
      gap: .25rem;
      font-size: .78rem;
      font-weight: 600;
      padding: .25rem .65rem;
      border-radius: 999px;
    }
    .hero-change-up { background: rgba(16,185,129,.2); color: #6ee7b7; }
    .hero-change-down { background: rgba(239,68,68,.2); color: #fca5a5; }
    .hero-change-flat { background: rgba(255,255,255,.1); color: rgba(255,255,255,.6); }

    /* ═══════════════ Hero Eye Toggle ═══════════════ */
    .hero-eye-toggle {
      background: none;
      border: none;
      color: rgba(255,255,255,.45);
      cursor: pointer;
      padding: .15rem .3rem;
      font-size: .8rem;
      border-radius: var(--pl-radius-xs);
      transition: color var(--pl-transition);
      position: relative;
      z-index: 1;
      vertical-align: middle;
      margin-left: .4rem;
    }
    .hero-eye-toggle:hover { color: rgba(255,255,255,.8); }

    /* ═══════════════ Hero Sparkline ═══════════════ */
    .hero-sparkline {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 60px;
      pointer-events: none;
      opacity: .4;
      z-index: 0;
    }
    .hero-sparkline svg {
      width: 100%;
      height: 100%;
    }
    .hero-sparkline-empty {
      font-size: .68rem;
      color: rgba(255,255,255,.25);
      text-align: center;
      line-height: 60px;
    }

    /* ═══════════════ Metric Cards ═══════════════ */
    .metric-card {
      background: var(--pl-surface);
      border: 1px solid var(--pl-border);
      border-radius: var(--pl-radius);
      padding: 1.15rem;
      box-shadow: var(--pl-shadow);
      transition: transform var(--pl-transition), box-shadow var(--pl-transition);
      height: 100%;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .metric-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--pl-shadow-hover);
    }
    .metric-card.metric-empty {
      border-style: dashed;
      opacity: .55;
    }
    .metric-card.metric-empty:hover {
      transform: none;
      box-shadow: var(--pl-shadow);
    }
    .metric-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: .65rem;
    }
    .metric-label {
      font-size: .72rem;
      font-weight: 500;
      color: var(--pl-text-3);
      text-transform: uppercase;
      letter-spacing: .03em;
    }
    .metric-icon {
      width: 30px; height: 30px;
      border-radius: var(--pl-radius-xs);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .85rem;
      background: var(--pl-accent-light);
      color: var(--pl-accent);
    }
    .metric-value {
      font-size: 1.4rem;
      font-weight: 700;
      font-variant-numeric: tabular-nums;
      letter-spacing: -.02em;
      line-height: 1.2;
    }
    .metric-sub { font-size: .7rem; color: var(--pl-text-3); margin-top: .3rem; }

    /* ═══════════════ Panel Cards ═══════════════ */
    .panel-card {
      background: var(--pl-surface);
      border: 1px solid var(--pl-border);
      border-radius: var(--pl-radius);
      box-shadow: var(--pl-shadow);
      overflow: hidden;
    }
    .panel-header {
      padding: .75rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--pl-border-light);
    }
    .panel-title { font-size: .82rem; font-weight: 600; color: var(--pl-text); }
    .panel-body { padding: 0; }
    .panel-body-scroll {
      max-height: 400px;
      overflow-y: auto;
      scrollbar-width: thin;
      scrollbar-color: var(--pl-border) transparent;
    }

    /* ═══════════════ Tables ═══════════════ */
    .pl-table {
      width: 100%;
      border-collapse: collapse;
      font-size: .82rem;
    }
    .pl-table thead th {
      position: sticky;
      top: 0;
      background: #fafbfc;
      font-size: .68rem;
      font-weight: 600;
      color: var(--pl-text-3);
      text-transform: uppercase;
      letter-spacing: .05em;
      padding: .55rem 1rem;
      border-bottom: 1px solid var(--pl-border);
      white-space: nowrap;
      z-index: 1;
    }
    .pl-table tbody td {
      padding: .55rem 1rem;
      border-bottom: 1px solid var(--pl-border-light);
      vertical-align: middle;
    }
    .pl-table tbody tr {
      transition: background var(--pl-transition);
    }
    .pl-table tbody tr:hover {
      background: rgba(99,102,241,.03);
    }
    .pl-table tbody tr:last-child td { border-bottom: none; }
    .text-tabular { font-variant-numeric: tabular-nums; }
    .text-end { text-align: right; }

    /* ═══════════════ Return Badges ═══════════════ */
    .return-badge {
      display: inline-flex;
      align-items: center;
      gap: .2rem;
      font-size: .7rem;
      font-weight: 600;
      padding: .18rem .5rem;
      border-radius: 999px;
      white-space: nowrap;
    }
    .return-up { color: #059669; background: var(--pl-green-bg); border: 1px solid var(--pl-green-border); }
    .return-down { color: #dc2626; background: var(--pl-red-bg); border: 1px solid var(--pl-red-border); }
    .return-flat { color: var(--pl-text-3); background: var(--pl-border-light); border: 1px solid var(--pl-border); }

    /* ═══════════════ Account Chip ═══════════════ */
    .account-chip {
      display: flex;
      align-items: center;
      gap: .55rem;
    }
    .account-avatar {
      width: 28px; height: 28px;
      border-radius: var(--pl-radius-xs);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: .7rem;
      font-weight: 600;
      color: #fff;
      background: linear-gradient(135deg, var(--pl-accent), #818cf8);
      flex-shrink: 0;
    }

    /* ═══════════════ Month Pill ═══════════════ */
    .month-pill {
      display: inline-flex;
      align-items: center;
      font-size: .76rem;
      font-weight: 500;
      padding: .12rem .45rem;
      border-radius: var(--pl-radius-xs);
      background: var(--pl-border-light);
      color: var(--pl-text-2);
    }

    /* ═══════════════ Sparkline ═══════════════ */
    .sparkline-cell {
      cursor: pointer;
      text-align: center;
      transition: opacity var(--pl-transition);
    }
    .sparkline-cell:hover { opacity: .7; }
    .sparkline-svg { display: inline-block; vertical-align: middle; }
    .sparkline-empty {
      font-size: .68rem;
      color: var(--pl-text-3);
      white-space: nowrap;
      cursor: default;
    }

    /* ═══════════════ Chart Modal ═══════════════ */
    .chart-modal-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 1050;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: fadeIn .15s ease;
    }
    .chart-modal-content {
      background: var(--pl-surface);
      border-radius: var(--pl-radius);
      width: 92%;
      max-width: 680px;
      box-shadow: 0 20px 60px rgba(0,0,0,.2);
      animation: fadeInUp .2s ease;
      overflow: hidden;
    }
    .chart-modal-header {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--pl-border-light);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .chart-modal-title { font-size: .95rem; font-weight: 600; }
    .chart-modal-meta {
      font-size: .72rem;
      color: var(--pl-text-3);
      padding: .5rem 1.25rem 0;
    }
    .chart-modal-body { padding: 1rem 1.25rem 1.25rem; }
    .chart-modal-close {
      background: none;
      border: 1px solid var(--pl-border);
      border-radius: var(--pl-radius-xs);
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--pl-text-2);
      font-size: .75rem;
      transition: all var(--pl-transition);
    }
    .chart-modal-close:hover { border-color: var(--pl-accent); color: var(--pl-accent); }

    /* ═══════════════ Buttons ═══════════════ */
    .btn-action {
      padding: .25rem .45rem;
      font-size: .72rem;
      border-radius: var(--pl-radius-xs);
      border: 1px solid var(--pl-border);
      background: var(--pl-surface);
      color: var(--pl-text-2);
      cursor: pointer;
      transition: all var(--pl-transition);
      line-height: 1;
    }
    .btn-action:hover { border-color: var(--pl-accent); color: var(--pl-accent); }
    .btn-action-danger { color: var(--pl-text-3); }
    .btn-action-danger:hover { border-color: var(--pl-red); color: var(--pl-red); }
    .btn-primary-pl {
      padding: .35rem .85rem;
      font-size: .76rem;
      font-weight: 600;
      border: none;
      border-radius: var(--pl-radius-xs);
      background: var(--pl-accent);
      color: #fff;
      cursor: pointer;
      transition: background var(--pl-transition);
      display: inline-flex;
      align-items: center;
      gap: .3rem;
    }
    .btn-primary-pl:hover { background: var(--pl-accent-hover); }

    /* ═══════════════ Toast ═══════════════ */
    #toastContainer { position: sticky; top: 60px; z-index: 200; }
    .pl-toast {
      padding: .55rem 1rem;
      font-size: .82rem;
      font-weight: 500;
      border-radius: var(--pl-radius-sm);
      margin-bottom: .5rem;
      animation: fadeInDown .2s ease;
    }
    .pl-toast-success { background: var(--pl-green-bg); color: #059669; border: 1px solid var(--pl-green-border); }
    .pl-toast-error { background: var(--pl-red-bg); color: #dc2626; border: 1px solid var(--pl-red-border); }

    /* ═══════════════ Modal Overrides ═══════════════ */
    .modal-content {
      border: 1px solid var(--pl-border);
      border-radius: var(--pl-radius);
      box-shadow: 0 20px 60px rgba(0,0,0,.15);
    }
    .modal-header { border-bottom: 1px solid var(--pl-border-light); padding: 1rem 1.25rem; }
    .modal-title { font-size: .95rem; font-weight: 600; }
    .modal-body { padding: 1.25rem; }
    .modal-body .form-label {
      font-size: .75rem; font-weight: 500; color: var(--pl-text-2); margin-bottom: .3rem;
    }
    .modal-body .form-control {
      border-radius: var(--pl-radius-xs);
      border: 1px solid var(--pl-border);
      font-size: .85rem;
      padding: .5rem .75rem;
    }
    .modal-body .form-control:focus {
      border-color: var(--pl-accent);
      box-shadow: 0 0 0 3px var(--pl-accent-light);
    }
    .modal-footer { border-top: 1px solid var(--pl-border-light); padding: .75rem 1.25rem; }

    /* ═══════════════ Animations ═══════════════ */
    @keyframes fadeIn {
      from { opacity: 0; }
      to { opacity: 1; }
    }
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-8px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .pl-table tbody tr { animation: fadeInUp .25s ease both; }

    /* ═══════════════ Toggle Link ═══════════════ */
    .pl-toggle-link {
      font-size: .72rem;
      color: var(--pl-accent);
      cursor: pointer;
      border: none;
      background: none;
      padding: .2rem .5rem;
      border-radius: var(--pl-radius-xs);
      transition: background var(--pl-transition);
    }
    .pl-toggle-link:hover { background: var(--pl-accent-light); }

    /* ═══════════════ Color utilities ═══════════════ */
    .text-green { color: var(--pl-green); }
    .text-red { color: var(--pl-red); }
    .text-muted-2 { color: var(--pl-text-2); }
    .text-muted-3 { color: var(--pl-text-3); }
    .fw-600 { font-weight: 600; }

    /* ═══════════════ Responsive 768px ═══════════════ */
    @media (max-width: 768px) {
      .quick-form { flex-wrap: wrap; }
      .quick-form .form-group { flex: 1 1 calc(50% - .375rem); }
      .quick-form .form-group-amount { flex: 1 1 calc(50% - .375rem); }
      .quick-form .btn-submit { flex: 1 1 100%; justify-content: center; }
      .hero-amount { font-size: 2rem; }
      .hero-card { min-height: 170px; padding: 1.25rem; }
    }

    /* ═══════════════ Responsive 576px ═══════════════ */
    @media (max-width: 576px) {
      .pl-container { padding: .75rem .75rem; }
      .quick-form { flex-direction: column; }
      .quick-form .form-group,
      .quick-form .form-group-amount { flex: 1 1 100%; }
      .hero-amount { font-size: 1.75rem; }
      .hero-card { min-height: 150px; padding: 1rem; }
      .metric-card { padding: .85rem; }
      .metric-value { font-size: 1.2rem; }
      .pl-table { font-size: .76rem; }
      .pl-table thead th { font-size: .62rem; padding: .45rem .65rem; }
      .pl-table tbody td { padding: .45rem .65rem; }
      .pl-navbar { height: 46px; }
      .pl-nav-status { display: none; }
      .account-chip { gap: .35rem; }
      .account-avatar { width: 24px; height: 24px; font-size: .62rem; }
      .btn-submit { width: 100%; justify-content: center; }
    }
  </style>
</head>
<body>
  <!-- ═══ Navbar ═══ -->
  <nav class="pl-navbar">
    <div class="pl-navbar-inner">
      <div class="pl-brand">
        <span class="pl-brand-dot"></span>
        Personal Ledger
      </div>
      <div class="pl-nav-actions">
        <span id="statusText" class="pl-nav-status">数据按需刷新</span>
        <button class="pl-btn-refresh" id="refreshBtn">刷新</button>
      </div>
    </div>
  </nav>

  <main class="pl-container">
    <div id="toastContainer" class="mb-3"></div>

    <!-- ═══ Quick Entry (collapsible horizontal) ═══ -->
    <div class="quick-card mb-3">
      <div class="quick-header" data-bs-toggle="collapse" data-bs-target="#quickBody" aria-expanded="true" aria-controls="quickBody">
        <span><i class="bi bi-pencil-square me-1"></i>快速记账</span>
        <i class="bi bi-chevron-down chevron-icon"></i>
      </div>
      <div class="collapse show" id="quickBody">
        <form id="quickSnapshotForm" class="quick-form">
          <div class="form-group">
            <label>账户</label>
            <select class="form-select" id="quickAccountSelect" name="account_id" required></select>
          </div>
          <div class="form-group">
            <label>月份</label>
            <input type="month" class="form-control" name="snapshot_month" value="<%= currentMonth %>" required />
          </div>
          <div class="form-group form-group-amount">
            <label>余额（RMB）</label>
            <div class="input-group">
              <span class="input-group-text">¥</span>
              <input type="text" class="form-control" name="balance" placeholder="120000.55" inputmode="decimal" required />
            </div>
          </div>
          <button type="submit" class="btn-submit">
            <i class="bi bi-check2-circle"></i>保存
          </button>
        </form>
      </div>
    </div>

    <!-- ═══ Row 1: Hero (col-5) + Metrics 2x2 (col-7) ═══ -->
    <div class="row g-3 mb-3">
      <div class="col-12 col-lg-5">
        <div class="hero-card h-100">
          <div>
            <div class="hero-label">Total Assets<button id="heroEyeToggle" class="hero-eye-toggle" title="显示/隐藏金额"><i class="bi bi-eye"></i></button></div>
            <div id="cardTotalRmb" class="hero-amount">0.00</div>
            <div id="heroChangeBadge" class="mt-2"></div>
          </div>
          <div class="hero-footer">
            <span class="hero-meta"><i class="bi bi-calendar3"></i><span id="cardLastDate">-</span></span>
            <span class="hero-meta"><i class="bi bi-currency-yen"></i>RMB</span>
          </div>
          <div id="heroSparkline" class="hero-sparkline"></div>
        </div>
      </div>
      <div class="col-12 col-lg-7">
        <div class="row g-3">
          <div class="col-6">
            <div class="metric-card">
              <div class="metric-header">
                <span class="metric-label">总资产变化</span>
                <span class="metric-icon"><i class="bi bi-graph-up-arrow"></i></span>
              </div>
              <div>
                <div id="cardTotalChange" class="metric-value text-tabular">-</div>
                <div id="cardTotalChangeRange" class="metric-sub">等待下月数据</div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="metric-card">
              <div class="metric-header">
                <span class="metric-label">总收益率</span>
                <span class="metric-icon"><i class="bi bi-percent"></i></span>
              </div>
              <div>
                <div id="cardTotalReturn" class="metric-value">-</div>
                <div class="metric-sub">按相邻两个月余额估算</div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="metric-card">
              <div class="metric-header">
                <span class="metric-label">账户数量</span>
                <span class="metric-icon"><i class="bi bi-wallet2"></i></span>
              </div>
              <div>
                <div id="cardAccountsCount" class="metric-value text-tabular">0</div>
              </div>
            </div>
          </div>
          <div class="col-6">
            <div class="metric-card">
              <div class="metric-header">
                <span class="metric-label">记录条数</span>
                <span class="metric-icon"><i class="bi bi-journal-check"></i></span>
              </div>
              <div>
                <div id="cardSnapshotsCount" class="metric-value text-tabular">0</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ Row 2: Account Performance (full width, with sparkline column) ═══ -->
    <div class="row g-3 mb-3">
      <div class="col-12">
        <div class="panel-card">
          <div class="panel-header">
            <span class="panel-title">账户表现</span>
            <div style="display:flex;align-items:center;gap:.5rem;">
              <button class="pl-toggle-link" id="toggleZeroAccounts">显示全部</button>
              <button class="btn-primary-pl" id="openAccountModalBtn">
                <i class="bi bi-plus"></i>新增
              </button>
            </div>
          </div>
          <div class="panel-body">
            <table class="pl-table">
              <thead>
                <tr>
                  <th style="width:22%;">账户</th>
                  <th class="text-end" style="width:22%;">余额 / 变动</th>
                  <th style="text-align:center;width:14%;">趋势</th>
                  <th class="text-end" style="width:22%;">收益率</th>
                  <th class="text-end" style="width:20%;">操作</th>
                </tr>
              </thead>
              <tbody id="accountsTbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══ Row 3: Recent Snapshots (full width, scrollable) ═══ -->
    <div class="row g-3">
      <div class="col-12">
        <div class="panel-card">
          <div class="panel-header">
            <span class="panel-title">余额记录</span>
            <div style="display:flex;align-items:center;gap:.5rem;">
              <select class="form-select" id="snapshotAccountFilter" style="width:auto;height:32px;font-size:.78rem;padding:0 .5rem 0 .4rem;border-radius:var(--pl-radius-xs);border:1px solid var(--pl-border);">
                <option value="">全部账户</option>
              </select>
              <input type="month" class="form-control" id="snapshotMonthFilter" value="<%= currentMonth %>" style="width:auto;height:32px;font-size:.78rem;padding:0 .5rem;border-radius:var(--pl-radius-xs);border:1px solid var(--pl-border);" />
              <button class="pl-toggle-link" id="exportCsvBtn" title="导出 CSV"><i class="bi bi-download"></i> 导出</button>
            </div>
          </div>
          <div class="panel-body panel-body-scroll">
            <table class="pl-table">
              <thead>
                <tr>
                  <th>日期</th>
                  <th>账户</th>
                  <th class="text-end">余额（RMB）</th>
                  <th class="text-end">操作</th>
                </tr>
              </thead>
              <tbody id="snapshotsTbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>

  <!-- ═══ Account Modal ═══ -->
  <div class="modal fade" id="accountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <form id="accountFormDialog">
          <div class="modal-header">
            <h5 class="modal-title" id="accountModalTitle">新增账户</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <input type="hidden" name="id" />
            <label class="form-label">账户名称</label>
            <input class="form-control" name="name" required placeholder="招商银行 / 币安现货 / 工资卡" />
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="font-size:.82rem;border-radius:var(--pl-radius-xs);">取消</button>
            <button type="submit" class="btn-primary-pl">保存</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- ═══ Chart Modal ═══ -->
  <div id="chartModalBackdrop" class="chart-modal-backdrop" style="display:none;">
    <div class="chart-modal-content">
      <div class="chart-modal-header">
        <span class="chart-modal-title" id="chartModalTitle"></span>
        <button class="chart-modal-close" id="chartModalClose"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="chart-modal-meta" id="chartModalMeta"></div>
      <div class="chart-modal-body">
        <canvas id="chartCanvas"></canvas>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script src="/app.js"></script>
</body>
</html>
